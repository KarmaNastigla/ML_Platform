# =============================================================
# Universal ML Platform — .gitignore
# =============================================================

# ── Модели и артефакты ML ─────────────────────────────────────
# Обученные модели — у каждого разработчика свои, весят много
model.pkl
*.pkl
*.joblib

# Папка деплоя генерируется автоматически через кнопку в UI
deploy/

# ── Данные ───────────────────────────────────────────────────
# CSV-датасеты не коммитим — могут быть конфиденциальными и большими
*.csv
*.tsv
*.parquet
*.feather
*.xlsx
*.xls
data/

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Виртуальные окружения
.venv/
venv/
env/
ENV/
.env

# Дистрибутив и сборка
build/
dist/
*.egg-info/
*.egg
.eggs/

# Покрытие тестов
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.tox/

# MyPy
.mypy_cache/
.dmypy.json

# ── Jupyter ───────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── IDE и редакторы ───────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Streamlit ─────────────────────────────────────────────────
# Кэш Streamlit — генерируется автоматически
.streamlit/cache/

# config.toml коммитим — в нём только лимит загрузки (не секреты)
# .streamlit/config.toml  ← НЕ игнорируем

# ── Логи ─────────────────────────────────────────────────────
*.log
logs/

# ── Переменные окружения и секреты ───────────────────────────
.env
.env.*
secrets.toml